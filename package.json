{
  "name": "aemet-client",
  "version": "0.1.0",
  "description": "Typed TypeScript client for the AEMET OpenData API (Spanish State Meteorological Agency). Used in production at snowy.es.",
  "keywords": [
    "aemet",
    "opendata",
    "weather",
    "meteorology",
    "spain",
    "forecast",
    "radar",
    "warnings",
    "cap",
    "api-client"
  ],
  "homepage": "https://github.com/jocarrd/aemet-client#readme",
  "bugs": {
    "url": "https://github.com/jocarrd/aemet-client/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jocarrd/aemet-client.git"
  },
  "license": "MIT",
  "author": "Jorge Carrera <jorgecarrera98d@gmail.com>",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "aemet-client": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "README.es.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "pnpm typecheck && pnpm test && pnpm build"
  },
  "engines": {
    "node": ">=20.18"
  },
  "packageManager": "pnpm@10.13.1",
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.4.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "fast-xml-parser": "^5.8.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}

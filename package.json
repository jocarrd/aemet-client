{
  "name": "aemet-client-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo: typed AEMET OpenData client and Model Context Protocol server.",
  "homepage": "https://github.com/jocarrd/aemet-client#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jocarrd/aemet-client.git"
  },
  "license": "MIT",
  "author": "Jorge Carrera <jorgecarrera98d@gmail.com>",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r --workspace-concurrency=1 test",
    "test:e2e": "pnpm --filter aemet-client test:e2e",
    "test:coverage": "pnpm --filter aemet-client test:coverage",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "engines": {
    "node": ">=20.18",
    "pnpm": ">=10"
  },
  "devDependencies": {
    "eslint": "^10.4.1",
    "prettier": "^3.4.2",
    "typescript-eslint": "^8.60.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}

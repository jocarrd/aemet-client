{
  "name": "aemet-client",
  "version": "0.4.1",
  "description": "Typed TypeScript client for the AEMET OpenData API (Spanish State Meteorological Agency). Used in production at snowy.es.",
  "keywords": [
    "aemet",
    "opendata",
    "weather",
    "meteorology",
    "spain",
    "forecast",
    "radar",
    "warnings",
    "cap",
    "api-client"
  ],
  "homepage": "https://github.com/jocarrd/aemet-client#readme",
  "bugs": {
    "url": "https://github.com/jocarrd/aemet-client/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jocarrd/aemet-client.git"
  },
  "license": "MIT",
  "author": "Jorge Carrera <jorgecarrera98d@gmail.com>",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./data": {
      "types": "./dist/data.d.ts",
      "import": "./dist/data.js",
      "require": "./dist/data.cjs"
    }
  },
  "bin": {
    "aemet-client": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "README.es.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "build:data": "node scripts/build-municipalities.mjs",
    "prepublishOnly": "pnpm build && pnpm typecheck && pnpm test"
  },
  "engines": {
    "node": ">=20.18"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "tsup": "^8.3.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "fast-xml-parser": "^5.8.0"
  }
}
